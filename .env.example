# ── Payment System MVP — Environment Variables ─────────────────────────────
# Copy this file to .env and adjust for your environment.
# All variables have safe defaults; .env is optional for local dev.
#
#   cp .env.example .env
#   docker compose up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────
DB_DSN=postgresql+asyncpg://payment:payment@localhost:5432/payment
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=info
APP_PORT=8000

# ── Idempotency ─────────────────────────────────────────────────────────
IDEMPOTENCY_TTL_SECONDS=2592000

# ── Outbox ──────────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_SECONDS=1.0
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_RETRIES=10

# ── Host port overrides (consumed by docker-compose.yml, not the app) ───
# APP_PORT=8030
# PG_PORT=5433
# REDIS_PORT=6380
